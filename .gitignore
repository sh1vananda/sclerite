# --- Rust / Engine ---
# Ignore the massive build artifacts
engine/target/
engine/build/
# Wrangler local state and dev cache
engine/.wrangler/
engine/tmp/
# If you use local secrets
engine/secrets.toml

# --- JavaScript / Interface ---
# The heaviest folder in the universe
interface/node_modules/
# Vite / Build outputs
interface/dist/
interface/.vite/
interface/.vite-temp/
# Local environment variables
interface/.env
interface/.env.local
interface/.env.development.local
interface/.env.test.local
interface/.env.production.local
# Log files
interface/npm-debug.log*
interface/yarn-debug.log*
interface/yarn-error.log*

# --- General ---
.env
*.log
